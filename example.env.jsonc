{
  // Copy this file to env.json and remove the comments.
  "token": "Discord bot token",
  "clientId": "Discord application client ID",
  "mongoUri": "MongoDB connection string, local or Atlas",
  "stateDatabaseName": "Optional: bot metadata database name, defaults to discordMongoClient",
  "devAdmins": [
    "Discord user ID that permanently has full access"
  ]
}

