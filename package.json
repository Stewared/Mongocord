{
  "name": "discord-mongo-client",
  "version": "0.1.0",
  "description": "An interactive Discord MongoDB client inspired by MongoDB Compass.",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "start": "node index.js",
    "register": "node launchCommands.js",
    "setup": "node setup.js",
    "pm2:start": "pm2 startOrRestart ecosystem.config.js --only mongocord",
    "pm2:stop": "pm2 stop mongocord",
    "pm2:status": "pm2 status mongocord"
  },
  "dependencies": {
    "discord.js": "^14.26.2",
    "jsonc": "^2.0.0",
    "mongodb": "^6.20.0"
  }
}

